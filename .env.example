# Environment variables for Pour Decisions / HangoverGPT
#
# For LOCAL DEVELOPMENT:
#   Copy this file to .streamlit/secrets.toml and fill in real values.
#   Streamlit reads secrets from .streamlit/secrets.toml (TOML format), NOT .env.
#   Format in secrets.toml — no quotes needed around plain strings:
#
#     MINIMAX_API_KEY = "your-key-here"
#     SUPABASE_URL    = "https://your-project-ref.supabase.co"
#     SUPABASE_KEY    = "your-anon-key"
#
# For PRODUCTION (Streamlit Community Cloud):
#   App → Settings → Secrets — paste the TOML key=value pairs and save.
#   Never commit .streamlit/secrets.toml to version control.

# ---------------------------------------------------------------------------
# Minimax AI — required for AI recommendations
# Obtain at: https://www.minimaxi.com/
# ---------------------------------------------------------------------------
MINIMAX_API_KEY=replace-me
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ---------------------------------------------------------------------------
# Supabase — required for the live PostgreSQL recipe database
# Find these in: Supabase Dashboard → Project Settings → API
# The app falls back to data/recipes.json when these are absent,
# so local dev works without them.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-public-key-here
