# Environment variables for Pour Decisions / HangoverGPT
#
# For LOCAL DEVELOPMENT:
#   Copy this file to .streamlit/secrets.toml and fill in real values.
#   Streamlit reads secrets from .streamlit/secrets.toml, NOT from a .env file.
#   Format in secrets.toml uses TOML syntax (no quotes needed around plain strings):
#
#     MINIMAX_API_KEY = "your-key-here"
#     MINIMAX_BASE_URL = "https://api.minimax.chat/v1"
#
# For PRODUCTION (Streamlit Community Cloud):
#   Add each variable via the Streamlit Cloud dashboard:
#   App → Settings → Secrets  (paste TOML key=value pairs, one per line)
#   Never commit .streamlit/secrets.toml to version control.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Minimax API key — obtain from https://www.minimaxi.com/
MINIMAX_API_KEY=replace-me

# ---------------------------------------------------------------------------
# Optional (defaults shown)
# ---------------------------------------------------------------------------

# Minimax API base URL (change only if using a different regional endpoint)
MINIMAX_BASE_URL=https://api.minimax.chat/v1
